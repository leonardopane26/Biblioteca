<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane id="AnchorPane" prefHeight="500.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="biblioteca.controller.VistaLibroController">
   <children>
      <VBox layoutY="1.0" prefHeight="550.0" prefWidth="500.0">
         <children>
            <Button fx:id="btnIndietro" mnemonicParsing="false" onAction="#goIndietro" text="Indietro">
               <VBox.margin>
                  <Insets left="20.0" top="20.0" />
               </VBox.margin>
            </Button>
            <Label prefHeight="21.0" prefWidth="106.0" text="Dettagli Libro">
               <VBox.margin>
                  <Insets left="180.0" />
               </VBox.margin>
            </Label>
            <GridPane hgap="10.0" vgap="10.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
               <children>
                  <Label alignment="CENTER_RIGHT" prefHeight="21.0" prefWidth="255.0" text="Titolo" />
                  <Label alignment="CENTER_RIGHT" prefHeight="21.0" prefWidth="245.0" text="Autori:" GridPane.rowIndex="1" />
                  <Label alignment="CENTER_RIGHT" prefHeight="21.0" prefWidth="274.0" text="codice ISBN:" GridPane.rowIndex="2" />
                  <Label alignment="CENTER_RIGHT" prefHeight="21.0" prefWidth="249.0" text="Copie disponibili:" GridPane.rowIndex="3" />
                  <Label fx:id="lblTitoloLibro" prefHeight="21.0" prefWidth="246.0" GridPane.columnIndex="1" />
                  <Label fx:id="lblAutoriLibro" prefHeight="21.0" prefWidth="251.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label fx:id="lblCodiceIsbn" prefHeight="21.0" prefWidth="253.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <Label fx:id="lblCopieDisponibili" prefHeight="21.0" prefWidth="257.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                  <Label alignment="CENTER_RIGHT" prefHeight="21.0" prefWidth="246.0" text="Copie totali:" GridPane.rowIndex="4" />
                  <Label fx:id="lblCopieTotali" prefHeight="27.0" prefWidth="245.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
               </children>
            </GridPane>
            <Label text="Utenti in possesso del libro">
               <VBox.margin>
                  <Insets left="160.0" top="20.0" />
               </VBox.margin>
            </Label>
            <TableView fx:id="tabellaLibroPrestato" prefHeight="200.0" prefWidth="500.0">
              <columns>
                <TableColumn fx:id="colNomeUtente" prefWidth="150.0" text="Nome Utente" />
                <TableColumn fx:id="colCognomeUtente" prefWidth="150.0" text="Cognome Utente" />
                  <TableColumn fx:id="colMatricolaUtente" prefWidth="150.0" text="Matricola" />
                  <TableColumn fx:id="colDataInizio" prefWidth="75.0" text="Data Inizio" />
                  <TableColumn fx:id="colDataFine" prefWidth="75.0" text="Data Fine" />
              </columns>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            <HBox prefHeight="100.0" prefWidth="200.0">
               <children>
                  <Button fx:id="btnElimina" alignment="BOTTOM_LEFT" mnemonicParsing="false" onAction="#eliminaLibro" text="Elimina">
                     <HBox.margin>
                        <Insets left="20.0" top="30.0" />
                     </HBox.margin>
                  </Button>
                  <Button fx:id="btnModifica" mnemonicParsing="false" onAction="#modificaLibro" text="Modifica">
                     <HBox.margin>
                        <Insets left="310.0" top="30.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
