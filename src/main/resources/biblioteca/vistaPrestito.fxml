<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="biblioteca.controller.VistaPrestitoController">
   <children>
      <VBox prefHeight="400.0" prefWidth="501.0">
         <children>
            <Label text="Dettagli Prestito">
               <VBox.margin>
                  <Insets left="190.0" top="20.0" />
               </VBox.margin>
            </Label>
            <GridPane hgap="10.0" vgap="10.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <VBox.margin>
                  <Insets top="50.0" />
               </VBox.margin>
               <children>
                  <Label alignment="CENTER_RIGHT" prefHeight="30.0" prefWidth="251.0" text="Titolo:" />
                  <Label fx:id="lblTitoloLibroPrestato" prefHeight="30.0" prefWidth="245.0" GridPane.columnIndex="1" />
                  <Label alignment="CENTER_RIGHT" prefHeight="29.0" prefWidth="246.0" text="Autore:" GridPane.rowIndex="1" />
                  <Label fx:id="lblAutoriLibroPrestato" prefHeight="30.0" prefWidth="248.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label alignment="CENTER_RIGHT" prefHeight="28.0" prefWidth="246.0" text="In prestito a:" GridPane.rowIndex="2" />
                  <Label fx:id="lblUtenteLibroPrestato" prefHeight="30.0" prefWidth="251.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <Label alignment="CENTER_RIGHT" prefHeight="29.0" prefWidth="246.0" text="Fino al:" GridPane.rowIndex="3" />
                  <Label fx:id="lblDataLibroPrestato" prefHeight="28.0" prefWidth="252.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
               </children>
            </GridPane>
            <HBox prefHeight="158.0" prefWidth="501.0">
               <children>
                  <Button fx:id="btnIndietro" mnemonicParsing="false" onAction="#goIndietro" text="Indietro">
                     <HBox.margin>
                        <Insets left="20.0" top="110.0" />
                     </HBox.margin>
                  </Button>
                  <Button fx:id="btnRestituisci" mnemonicParsing="false" onAction="#apriFinestraRestituzione" text="Restituisci">
                     <HBox.margin>
                        <Insets left="300.0" top="110.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
